# Copy to .env and fill in the notifiers you're using. Never commit .env.

# Discord webhook for real-time alerts. Server Settings > Integrations >
# Webhooks > New Webhook > Copy Webhook URL.
DISCORD_WEBHOOK_URL=

# Gmail account used to send the nightly digest email.
# GMAIL_APP_PASSWORD requires 2FA enabled on the account:
# https://myaccount.google.com/apppasswords
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=

# Optional. Only used to raise the GitHub API rate limit for the GitHub
# repo scraper. In CI this is provided automatically by GitHub Actions.
GITHUB_TOKEN=
